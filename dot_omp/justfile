############################################################
## Update
############################################################

# Install / Update via official installer
[group('Update')]
install:
  curl -fsSL https://omp.sh/install | sh

uninstall-mise:
  mise remove -g github:can1357/oh-my-pi

# Update via mise
[group('Update')]
update-via-mise min-age='0s':
    mise self-update -y || true
    MISE_GITHUB_ATTESTATIONS=false \
      mise upgrade --minimum-release-age {{ min-age }}

    # Update ssh config in case we updated assh
    mise x -- assh config build > ~/.ssh/config

############################################################
## Authentication Helpers
############################################################

# Open an ssh tunnel on your local machine to a remote machine to do OAuth callback routing
[group('OAuth')]
oauth-callback-tunnel machine port:
    @printf "Opening tunnel to forward localhost:{{ port }} on {{ machine }} to your local machine\n"
    @printf "You will not see any output, just Ctrl+C after you are done"
    ssh -L {{ port }}:localhost:{{ port }} -N {{ machine }}

# Open a Codex OAuth callback tunnel on your local machine to a remote machine
[group('Codex')]
[group('OAuth')]
codex-oauth-callback-tunnel machine port='1455':
    @just oauth-callback-tunnel {{ machine }} {{ port }}

