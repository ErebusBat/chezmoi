# vim: set ft=confini tabstop=2 shiftwidth=2 expandtab:

# THIS FILE IS MANAGED BY CHEZMOI:
#   chezmoi edit ~/.gitconfig

# This is Git's per-user configuration file.
[user]
  name = Andrew Burns
  email = {{ .email }}
  {{- if eq .focus "lshq" }}
  signingkey = {{ .chezmoi.homeDir }}/.ssh/gh_signing_ed25519_2026-02-25T00:04:06Z.pub
  {{- end }}

[color]
  branch = auto
  status = auto
  diff = auto
  ui = true

[alias]
  br = branch
  ci = commit
  co = checkout
  cp = cherry-pick
  df = diff
  g = \"!git gui\"
  k = !gitk
  lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
  lsig = ls-files --others -i --exclude-standard
  rem = remote
  st = status
  who = shortlog -s --
  lol = log --decorate --oneline --graph
  sync = !git pull --rebase --autostash && git push
  syncsm = !git pull --rebase --autostash && git push && git submodule update --init --recursive

[core]
  excludesfile = ~/.git-ignore
  quotepath = false
  ; attributesFile = /Users/{{ .chezmoi.group }}/.gitattributes
  pager = delta

[interactive]
  diffFilter = delta --color-only

[push]
  default = simple

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  required = true
  process = git-lfs filter-process

[merge]
  conflictstyle = diff3

[pager]
  difftool = true

[difftool "sourcetree"]
  cmd = opendiff \"$LOCAL\" \"$REMOTE\"
  path =

[difftool "difftastic"]
  cmd = difft "$LOCAL" "$REMOTE"

[mergetool "sourcetree"]
  cmd = /Applications/SourceTree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
  trustExitCode = true

[diff]
  colorMoved = default

[difftool]
  prompt = false

[diff "code"]
  wordRegex = [^[:space:],()\\.]+

[delta]
  navigate = true
  line-numbers = true
  # side-by-side = true
  # light = false
  minus-style = red normal
  minus-non-emph-style = red normal
  minus-emph-style = bold red "#3f0001"
  minus-empty-line-marker-style = red normal
  plus-style = green normal
  plus-non-emph-style = green normal
  plus-emph-style = bold green "#002800"
  plus-empty-line-marker-style = green normal

[diff-so-fancy]
  markEmptyLines = false

[github]
  user = ErebusBat

[pull]
  rebase = false

[credential "https://github.com"]
  helper = !gh auth git-credential

[color "diff-highlight"]
  oldNormal = red bold
  oldHighlight = red bold 52
  newNormal = green bold
  newHighlight = green bold 22

[color "diff"]
  meta = 11
  frag = magenta bold
  func = 146 bold
  commit = yellow bold
  old = red bold
  new = green bold
  whitespace = red reverse

[safe]
{{- if eq .focus "server" }}
  directory = /myserver
{{- end }}
[init]
  defaultBranch = main
{{- if eq .focus "lshq" }}
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg "ssh"]
	allowedSignersFile = {{ .chezmoi.homeDir }}/.ssh/allowed_signers
{{- end }}
