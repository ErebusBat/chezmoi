#!/bin/bash
{{ $manual_update_monotonic := 20260714.0 }}
{{ $filePath := joinPath .chezmoi.homeDir "/.config/mise/config.toml" }}
{{ $force_update_every_days := 3 }}
{{ $update_version := div (now | unixEpoch) (mul $force_update_every_days 86400) }}
{{ if stat $filePath }}
# Config HASH: {{ include $filePath | sha256sum }} ~/.config/mise/config.toml
# manual_monotonic={{ $manual_update_monotonic }} <== Manual value that can be updated above to force the script to run.
# update_version={{ $update_version }} <-- Will update every {{ $force_update_every_days }}d
echo "MISE: Updating..."
cd ~
if command -v mise &>/dev/null; then
  # Remove NPM managed codex
  # npm uninstall -g @openai/codex
  # rm /home/aburns/.local/bin/codex 2>&1 >/dev/null || true

  # upgrade the mise tool
  mise self-update -y

  # Upgrade mise packages
  mise upgrade --minimum-release-age 0s
  mise_ec=$?
  if (( mise_ec != 0 )); then
      printf "\n\n🚨 IMPORTANT: If you are getting 'GitHub artifact attestations verification error' when upgrading then you can work around that with:\n"
      printf "\tMISE_GITHUB_ATTESTATIONS=false mise upgrade --minimum-release-age 0s && chezmoi update\n\n"
  fi

  # Update ssh config in case we updated assh
  mise x -- assh config build > ~/.ssh/config
else
  echo "WARN: mise not installed yet!"
fi
{{ else }}
# Config file {{ $filePath }} not found!
# Script Generated On: {{ (now).Format "2006-01-02 15:04:05" }}
echo "MISE: Not updating, no config"
{{ end }}

