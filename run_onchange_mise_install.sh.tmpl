#!/bin/bash
{{ $filePath := joinPath .chezmoi.homeDir "/.config/mise/config.toml" }}
{{ if stat $filePath }}
# Config HASH: {{ include $filePath | sha256sum }} ~/.config/mise/config.toml
echo "MISE: Syncing..."
cd ~
if command -v mise &>/dev/null; then
  mise install
else
  echo "WARN: mise not installed yet!"
  echo "      attempting to install with: curl https://mise.run | sh"
  curl https://mise.run | sh
fi
{{ else }}
# Config file {{ $filePath }} not found!
# Script Generated On: {{ (now).Format "2006-01-02 15:04:05" }}
echo "MISE: Not running, no config"
{{ end }}
