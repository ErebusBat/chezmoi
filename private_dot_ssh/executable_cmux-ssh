#!/usr/bin/env zsh
# cmux-ssh — open cmux SSH workspace inside a named sidebar group
# Usage: cmux-ssh <host>

set -euo pipefail

# ── Config ────────────────────────────────────────────────────────────
SERVER_GROUP_NAME='🌐Servers'

# ── Args ──────────────────────────────────────────────────────────────
local HOST="${1:-}"
if [[ -z "$HOST" ]]; then
  print -u2 "Usage: ${0:t} <host>"
  exit 1
fi

# ── Discover the group dynamically ────────────────────────────────────
local GROUP_JSON
GROUP_JSON=$(cmux workspace-group list --json 2>/dev/null)

local GROUP_REF
GROUP_REF=$(jq -r --arg name "$SERVER_GROUP_NAME" '.groups[] | select(.name == $name) | .ref' <<<"$GROUP_JSON")

local ANCHOR_WS
ANCHOR_WS=$(jq -r --arg name "$SERVER_GROUP_NAME" '.groups[] | select(.name == $name) | .anchor_workspace_ref' <<<"$GROUP_JSON")

if [[ -z "$GROUP_REF" || "$GROUP_REF" == "null" ]]; then
  print -u2 "Error: group '$SERVER_GROUP_NAME' not found"
  exit 1
fi

# ── Discover which window the anchor workspace lives in ───────────────
local WINDOW_REF
WINDOW_REF=$(cmux workspace list --json 2>/dev/null | jq -r --arg ws "$ANCHOR_WS" '
  .window_ref as $win |
  .workspaces[] |
  select(.ref == $ws) |
  $win
')

if [[ -z "$WINDOW_REF" || "$WINDOW_REF" == "null" ]]; then
  print -u2 "Error: could not resolve window for anchor $ANCHOR_WS"
  exit 1
fi

# ── Create SSH workspace in that window, without focusing ──────────────
cmux ssh -A --name "$HOST" --no-focus --window "$WINDOW_REF" "$HOST"

# ── Find the newly created workspace by remote.destination ────────────
sleep 0.4
local NEW_WS
NEW_WS=$(cmux workspace list --json --window "$WINDOW_REF" 2>/dev/null | jq -r --arg host "$HOST" '
  .workspaces[] | select(.remote.destination == $host) | .ref
' | tail -1)

if [[ -z "$NEW_WS" || "$NEW_WS" == "null" ]]; then
  print -u2 "Error: could not find new workspace for host $HOST"
  exit 1
fi

# ── Add it to the group and focus ─────────────────────────────────────
cmux workspace-group add --group "$GROUP_REF" --workspace "$NEW_WS"
cmux workspace select "$NEW_WS"

print "SSH workspace $NEW_WS added to $GROUP_REF ($SERVER_GROUP_NAME)"
