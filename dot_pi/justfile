# Pi coding agent management

# Install pi globally
[script]
install:
  #!/usr/bin/env bash
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
  nvm use --silent >/dev/null
  npm install -g @mariozechner/pi-coding-agent

# Upgrade pi to the latest version
[script]
upgrade:
  #!/usr/bin/env bash
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
  nvm use --silent >/dev/null
  npm install -g @mariozechner/pi-coding-agent@latest

# Show current pi version
[script]
version:
  #!/usr/bin/env bash
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
  nvm use --silent >/dev/null
  pi --version

# Start pi with the zai provider
[script]
zai:
  #!/usr/bin/env bash
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
  nvm use --silent >/dev/null
  pi --provider zai

# Start pi with the OpenAI provider
[script]
openai:
  #!/usr/bin/env bash
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
  nvm use --silent >/dev/null
  pi --provider openai

# Alias for openai
alias oai := openai
