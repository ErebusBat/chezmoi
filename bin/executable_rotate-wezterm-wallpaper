#!/bin/zsh
# vim: ft=zsh sw=2 ts=2 et

################################################################################
## Configuration
################################################################################
CONFIG_DIR=~/.config/wezterm
RUBY_SCRIPT=${CONFIG_DIR}/rotate-wallpaper

################################################################################
## Entry Point
################################################################################
if [[ ! -x $RUBY_SCRIPT ]]; then
  echo "ERROR: Could not find wallpaper rotation script: $RUBY_SCRIPT"
  exit 1
fi

if ! command -v mise >/dev/null 2>&1; then
  echo "ERROR: Could not find mise in PATH"
  exit 1
fi

mise x ruby@3.4 -- "$RUBY_SCRIPT"
