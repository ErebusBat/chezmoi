#!/bin/sh
# cmux-notify — fire a cmux desktop notification.
#
# Standalone replacement for the old cmux-notify zsh function, extended to work
# over `cmux ssh` remote sessions as well as locally.
#
#   cmux-notify [body] [subtitle]
#
# Default body is "Task Completed"; default subtitle is the current directory.
# Silently no-ops when not inside a cmux surface.
#
# Detects a `cmux ssh` remote session via CMUX_REMOTE_TRANSPORT. The local
# desktop cmux accepts --title/--subtitle/--body/--surface; a remote relay
# session only accepts --title/--body (the current surface is implicit and
# --subtitle/--surface are rejected).

set -u

title="👀 Notification"
body="${1:-Task Completed}"
subtitle="${2:-}"

# Nothing to notify against without a surface.
[ -n "${CMUX_SURFACE_ID:-}" ] || exit 0

# Need the CLI.
if ! command -v cmux >/dev/null 2>&1; then
  echo "cmux-notify: cmux command not found" >&2
  exit 1
fi

# Mirror the old function: default the subtitle to the cwd basename + "/".
if [ -z "$subtitle" ]; then
  subtitle="$(basename "${PWD:-/}")/"
fi

# Non-empty CMUX_REMOTE_TRANSPORT => we're inside a `cmux ssh` session, whose
# relay daemon only supports --title/--body.
if [ -n "${CMUX_REMOTE_TRANSPORT:-}" ]; then
  # No subtitle field remotely — fold the context into the body.
  if [ -n "$subtitle" ]; then
    body="$body ($subtitle)"
  fi
  cmux notify --title "$title" --body "$body" >/dev/null
else
  cmux notify \
    --title "$title" \
    --subtitle "$subtitle" \
    --body "$body" \
    --surface "$CMUX_SURFACE_ID" >/dev/null
fi
