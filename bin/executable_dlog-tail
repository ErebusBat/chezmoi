#!/bin/zsh
set -e

WATCH=${1:-0}

# Maximum wait in seconds for fswatch to report a change; <=0 waits indefinitely.
DLOG_FSWATCH_TIMEOUT="${DLOG_FSWATCH_TIMEOUT:-900}"

# display message and pause if we're in watch mode.
if [[ $WATCH -gt 0 ]]; then
  echo "***  INFO: Watch mode enabled"
  sleep 2
fi

# Setup paths, support known locations for vault root
LOGS_PATH="logs/$(date +%Y/%m-%b)"
FILE_NAME="$(date +%F-%a).md"
WIKI_ROOT_PATHS=(
  ~/Documents/Obsidian/vimwiki   # Personal Mac
  ~/Documents/vimwiki            # LightspeedHQ Mac
  ~/Sync/Obsidian/vimwiki        # Thelio (SyncThing)
  ~/vimwiki                      # Thelio (Obsidian)
)

# Find root path, error if not found
for p in $WIKI_ROOT_PATHS; do
  if [[ -d $p ]]; then
    WIKI_ROOT_PATH=$p
    break
  fi
done
if [[ ! -d $WIKI_ROOT_PATH ]]; then
  echo "*** FATAL: Could not find wiki root path!"
  exit 1
fi

# Build final paths
FULL_DIR_PATH="$WIKI_ROOT_PATH/$LOGS_PATH"
FULL_FILE_PATH="$FULL_DIR_PATH/$FILE_NAME"

function show-dlog() {
  # echo "${FULL_FILE_PATH}"
  echo "${FULL_FILE_PATH/#$WIKI_ROOT_PATH/vault:}"
  if [[ -x $(which glow) ]]; then
    grep '^# Log' -A50 $FULL_FILE_PATH | glow -w $COLUMNS --style ~/.config/dlog/glow.json
  else
    grep '^# Log' -A50 $FULL_FILE_PATH
  fi
}

# Finally run the command
if [[ $WATCH -le 0 ]]; then
  show-dlog
  exit 0
fi

### Looping / Watching
function wait-dumb() {
  echo "*** WARN: Consider installing fswatch for a better experience"
  sleep $WATCH
}

function wait-fswatch() {
  local event fswatch_pid fswatch_status read_status
  local timed_out=0

  coproc "${FSWATCH_CMD[@]}"
  fswatch_pid=$!

  set +e
  if (( DLOG_FSWATCH_TIMEOUT > 0 )); then
    read -r -t "$DLOG_FSWATCH_TIMEOUT" -p event
  else
    read -r -p event
  fi
  read_status=$?

  if (( read_status != 0 )) && kill -0 "$fswatch_pid" 2>/dev/null; then
    timed_out=1
    kill -TERM "$fswatch_pid" 2>/dev/null
  fi
  wait "$fswatch_pid"
  fswatch_status=$?
  set -e

  if (( timed_out )); then
    echo "*** INFO: Timeout fired"
  elif (( fswatch_status != 0 )); then
    echo "*** WARN: Caught fswatch ec=$fswatch_status; exiting loop!"
    exit "$fswatch_status"
  fi
}

### Main Loop

FSWATCH_CMD=
if command -v fswatch >/dev/null 2>&1; then
  FSWATCH_CMD=(fswatch -1 "$FULL_FILE_PATH")
fi
while [ true ]; do
  # Clear the screen and then launch us but without a loop parameter this ensures that any day rollover gets picked up correctly and we show the correct log.
  clear
  $0
  printf "Last update: %s\n" "$(date)"

  if [[ -n $FSWATCH_CMD ]]; then
    wait-fswatch
  else
    wait-dumb
  fi
done

