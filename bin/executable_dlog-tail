#!/bin/zsh
set -e

WATCH=${1:-0}
if [[ $WATCH -gt 0 ]]; then
  echo "***  INFO: Watch mode enabled"
fi

# Set timeout for fswatch. Blank value defaults to 1 hour. <=0 disables timeout.
DLOG_FSWATCH_TIMEOUT="${DLOG_FSWATCH_TIMEOUT:-3600}"
if [[ $WATCH -gt 0 && $DLOG_FSWATCH_TIMEOUT -gt 0 ]]; then
  if ! command -v timeout >/dev/null 2>&1; then
    echo "***  WARN: Watch mode NOT using fswatch timeout (no timeout cmd)!"
    sleep 5
    DLOG_FSWATCH_TIMEOUT=0
  fi
elif (( DLOG_FSWATCH_TIMEOUT <= 0 )); then
  DLOG_FSWATCH_TIMEOUT=0
fi

# Keep for set -u compatibility in branches where the command may not run.
FSWATCH_STATUS=0

# Setup paths, support known locations for vault root
LOGS_PATH="logs/$(date +%Y/%m-%b)"
FILE_NAME="$(date +%F-%a).md"
WIKI_ROOT_PATHS=(
  ~/Documents/Obsidian/vimwiki   # Personal Mac
  ~/Documents/vimwiki            # LightspeedHQ Mac
  ~/Sync/Obsidian/vimwiki        # Thelio (SyncThing)
  ~/vimwiki                      # Thelio (Obsidian)
)

# Find root path, error if not found
for p in $WIKI_ROOT_PATHS; do
  if [[ -d $p ]]; then
    WIKI_ROOT_PATH=$p
    break
  fi
done
if [[ ! -d $WIKI_ROOT_PATH ]]; then
  echo "*** FATAL: Could not find wiki root path!"
  exit 1
fi

# Build final paths
FULL_DIR_PATH="$WIKI_ROOT_PATH/$LOGS_PATH"
FULL_FILE_PATH="$FULL_DIR_PATH/$FILE_NAME"

function show-dlog() {
  echo "${FULL_FILE_PATH}"
  if [[ -x $(which glow) ]]; then
    grep '^# Log' -A50 $FULL_FILE_PATH | glow -w $COLUMNS --style ~/.config/dlog/glow.json
  else
    grep '^# Log' -A50 $FULL_FILE_PATH
  fi
}

# Finally run the command
if [[ $WATCH -le 0 ]]; then
  show-dlog
  exit 0
fi

### Looping / Watching
function wait-dumb() {
  echo "*** WARN: Consider installing fswatch for a better experience"
  sleep $WATCH
}

function wait-fswatch() {
  local cmd=("${FSWATCH_CMD[@]}")
  if (( DLOG_FSWATCH_TIMEOUT > 0 )); then
    cmd=(timeout --foreground "$DLOG_FSWATCH_TIMEOUT" "${cmd[@]}")
  fi

  # Have to modify the output here, otherwise any non-zero exit code
  # from timeout will kill the script and not return control.
  set +e
  "${cmd[@]}" 2>&1 1>/dev/null
  FSWATCH_STATUS=$?
  set -e

  # handle our non-zero exit code. 124 is timeout, so we ignore that.
  if (( FSWATCH_STATUS != 0 && FSWATCH_STATUS != 124 )); then
    echo "*** WARN: Caught fswatch ec=$FSWATCH_STATUS; exiting loop!"
    exit "$FSWATCH_STATUS"
  fi
}

### Main Loop

FSWATCH_CMD=
if command -v fswatch >/dev/null 2>&1; then
  FSWATCH_CMD=(fswatch -1 "$FULL_FILE_PATH")
fi
while [ true ]; do
  clear
  show-dlog
  if [[ -n $FSWATCH_CMD ]]; then
    wait-fswatch
  else
    wait-dumb
  fi
done

