# https://ghostty.zerebos.com/
# cmd+shift+, = reload config
#
# Config generated by Ghostty Config
# https://ghostty.zerebos.com

background = #fbf1c7
clipboard-read = allow
copy-on-select = clipboard
cursor-color = black
cursor-opacity = 0.25
cursor-style-blink = true
cursor-text = #fbf1c7
font-family = "Atkinson Hyperlegible Mono"
font-family-bold = "Atkinson Hyperlegible Mono Bold"
font-family-italic = "Atkinson Hyperlegible Mono Italic"
font-size = 16
font-thicken = true
font-thicken-strength=0
foreground = #3c3836
keybind = global:ctrl+shift+grave_accent=toggle_quick_terminal
keybind = global:ctrl+shift+grave_accent=toggle_quick_terminal
keybind = cmd+shift+left_bracket=previous_tab
keybind = cmd+shift+right_bracket=next_tab
keybind = ctrl+shift+left_bracket=text:\x01p
keybind = ctrl+shift+right_bracket=text:\x01n
keybind = shift+ctrl+,=move_tab:-1
keybind = shift+ctrl+.=move_tab:+1
keybind = ctrl+alt+shift+cmd+f12=text:\x1b[90~
keybind = ctrl+alt+shift+cmd+f11=text:\x1b[91~
link-url = true
macos-option-as-alt = true
mouse-hide-while-typing = true
notify-on-command-finish = unfocused
notify-on-command-finish-action = notify
palette = 0=#fbf1c7
palette = 1=#cc241d
palette = 2=#98971a
palette = 3=#d79921
palette = 4=#458588
palette = 5=#b16286
palette = 6=#689d6a
palette = 7=#7c6f64
palette = 8=#928374
palette = 9=#9d0006
palette = 10=#79740e
palette = 11=#b57614
palette = 12=#076678
palette = 13=#8f3f71
palette = 14=#427b58
palette = 15=#3c3836
palette-harmonious = true
quick-terminal-animation-duration = 0.1
selection-background = #3c3836
selection-foreground = #fbf1c7
theme = Gruvbox Light
title-report = true
working-directory = home

