# cmd+shift+, = reload config

# Appearance
cursor-invert-fg-bg = true
cursor-style = block_hollow
# theme = dark:catppuccin-frappe,light:catppuccin-latte
theme = "tinted-theming"
window-theme = system

# System
clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard
focus-follows-mouse = true
link-url = true
macos-option-as-alt = true
mouse-hide-while-typing = true
working-directory = home

#
# Quake Term
#
keybind = global:ctrl+shift+grave_accent=toggle_quick_terminal
quick-terminal-animation-duration = 0.1

#
# Font
#
font-size = 16
# font-family = "Comic Code Ligatures"

# => -> -->  == === != !=== 0Oo 8Bb 1lL
font-family = "Atkinson Hyperlegible Mono"
# font-family = "Atkinson Hyperlegible Mono Medium"
font-family-bold = "Atkinson Hyperlegible Mono Bold"
font-family-italic = "Atkinson Hyperlegible Mono Italic"

# font-family = "Comic Code"8B8
# font-family = "Monaspace Argon"
# font-family-bold = "Monaspace Krypton Var Regular Bold Italic"
# font-family-italic = "Monaspace Krypton Var Regular Italic"
# font-feature = calt
# font-feature = liga
# font-feature = dlig
# font-feature = ss01
# font-feature = ss02
# font-feature = ss03
# font-feature = ss04
# font-feature = ss05
# font-feature = ss06
# font-feature = ss07
# font-feature = ss08
# font-feature = ss09

# Keybindings
keybind = global:ctrl+shift+grave_accent=toggle_quick_terminal
keybind = cmd+shift+left_bracket=previous_tab
keybind = cmd+shift+right_bracket=next_tab
# tmux window nav: send prefix (C-a) + n/p since Ghostty doesn't pass C-S-[ ] reliably
keybind = ctrl+shift+left_bracket=text:\x01p
keybind = ctrl+shift+right_bracket=text:\x01n
keybind = shift+ctrl+,=move_tab:-1
keybind = shift+ctrl+.=move_tab:+1
# Hyper+F12 -> tmux user-keys[1] for clear attention
keybind = ctrl+alt+shift+cmd+f12=text:\x1b[90~
# Hyper+F11 -> tmux user-keys[2] for confirm-before kill-window
keybind = ctrl+alt+shift+cmd+f11=text:\x1b[91~
