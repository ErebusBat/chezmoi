#!/usr/bin/env ruby

require 'optparse'
require 'pathname'
require 'yaml'
require_relative 'lib/wallpaper_config'

STATIC_FILE = Pathname.new('/tmp/wezterm-wallpaper.static').freeze
CONFIG_FILE = Pathname.new('~/.config/wezterm/wallpaper.yaml').expand_path.freeze
LINK_TARGET = Pathname.new('~/.config/wezterm/wallpaper.jpg').expand_path.freeze
SUPPORTED_EXTENSIONS = %w[.jpg .jpeg .png .webp .gif .bmp .tif .tiff].freeze

class WallpaperRotator
  Entry = Struct.new(:path, :weight, :source, :weight_detail, keyword_init: true)

  def initialize(config_file:, static_file:, link_target:, force:, dry_run:, verbose_level:)
    @config_file = config_file
    @static_file = static_file
    @link_target = link_target
    @force = force
    @dry_run = dry_run
    @verbose_level = verbose_level
    @selected_groups = []
  end

  attr_accessor :selected_groups

  def run
    enforce_static_mode

    config_entries = parse_config
    entries = build_weighted_entries(config_entries)
    abort('No valid wallpaper candidates found from configuration.') if entries.empty?

    selection = choose_weighted(entries)
    chosen = selection[:entry]

    if verbose?
      puts color('Weighted candidates:', :header)
      puts format(
        '  %s=%s (range: %s)',
        color('random_pick', :label),
        color(selection[:pick].to_s, :pick),
        color("0..#{selection[:total] - 1}", :range)
      )

      running = 0
      WallpaperConfig.sort_entries_for_display(entries).each do |entry|
        range_start = running
        running += entry.weight
        range_end = running - 1
        marker = entry.equal?(chosen) ? color('->', :pick) : '  '

        puts format(
          '%s %s=%-4d %s=[%4d..%-4d] %s %s',
          marker,
          color('sum', :label),
          running,
          color('range', :label),
          range_start,
          range_end,
          short_path(entry.path),
          source_suffix(entry)
        )

        puts format(
          '%11s%s=%s',
          '',
          color('weight', :label),
          entry.weight_detail || entry.weight.to_s
        )
        puts
      end
      puts
    end

    if @dry_run
      puts "Dry run: would link #{@link_target}\n  -> #{chosen.path}"
      return 0
    end

    update_symlink(chosen.path)
    puts "-> #{chosen.path}"
    0
  end

  private

  def enforce_static_mode
    return unless @static_file.exist?

    if @dry_run
      warn "WARNING: #{@static_file} exists; dry-run will not remove static mode marker"
      return
    end

    if @force
      @static_file.delete
      puts "Removed static mode marker #{@static_file}"
    else
      abort("Not rotating; #{@static_file} exists (use --force to rotate anyway)")
    end
  end

  def parse_config
    WallpaperConfig.new.parse(@config_file, selected_groups: @selected_groups)
  rescue WallpaperConfig::ConfigError => e
    abort(e.message)
  end

  def build_weighted_entries(config_entries)
    excluded = collect_excluded_paths(config_entries)

    seen = {}
    entries = []

    config_entries.each do |entry|
      source_path = entry.path
      next if source_path.nil? || source_path.to_s.strip.empty?

      enabled = entry.effective_enabled?
      next unless enabled

      weight = entry.effective_weight
      recurse = entry.recurse.to_i
      next if weight <= 0

      expand_paths(source_path.to_s, recurse: recurse).each do |path|
        next unless wallpaper_file?(path)
        real = path.realpath
        next if excluded.key?(real.to_s)
        next if seen.key?(real.to_s)

        seen[real.to_s] = true
        entries << Entry.new(
          path: real,
          weight: weight,
          source: source_path,
          weight_detail: entry.weight_breakdown
        )
      rescue Errno::ENOENT
        next
      end
    end

    entries
  end

  def collect_excluded_paths(config_entries)
    excluded = {}

    config_entries.each do |entry|
      source_path = entry.path
      next if source_path.nil? || source_path.to_s.strip.empty?

      enabled = entry.effective_enabled?
      next if enabled

      recurse = entry.recurse.to_i
      expand_paths(source_path.to_s, recurse: recurse).each do |path|
        next unless wallpaper_file?(path)
        real = path.realpath
        excluded[real.to_s] = true
      rescue Errno::ENOENT
        next
      end
    end

    excluded
  end

  def expand_paths(raw_path, recurse:)
    expanded = File.expand_path(raw_path)
    if glob_pattern?(expanded)
      Dir.glob(expanded).flat_map { |path| expand_paths(path, recurse: recurse - 1) }
    else
      path = Pathname.new(expanded)
      return [] unless path.exist?

      if path.directory?
        recurse_children(path, recurse)
      else
        [path]
      end
    end
  end

  def recurse_children(directory, recurse)
    return [] if recurse < 0

    directory.children.flat_map do |child|
      if child.directory?
        recurse_children(child, recurse - 1)
      else
        [child]
      end
    end
  end

  def glob_pattern?(path)
    path.match?(/[\*\?\[\{]/)
  end

  def wallpaper_file?(path)
    path.file? && SUPPORTED_EXTENSIONS.include?(path.extname.downcase)
  end

  def choose_weighted(entries)
    total = entries.sum(&:weight)
    pick = rand(total)
    running = 0

    entries.each do |entry|
      range_start = running
      running += entry.weight
      if pick < running
        return {
          entry: entry,
          pick: pick,
          total: total,
          range_start: range_start,
          range_end: running - 1,
        }
      end
    end

    {
      entry: entries.last,
      pick: total - 1,
      total: total,
      range_start: total - entries.last.weight,
      range_end: total - 1,
    }
  end

  def update_symlink(chosen_path)
    @link_target.dirname.mkpath
    tmp_link = Pathname.new("#{@link_target}.tmp-#{Process.pid}")

    tmp_link.delete if tmp_link.exist? || tmp_link.symlink?
    File.symlink(chosen_path.to_s, tmp_link.to_s)
    File.rename(tmp_link.to_s, @link_target.to_s)
  ensure
    tmp_link.delete if tmp_link && (tmp_link.exist? || tmp_link.symlink?)
  end

  def short_path(path)
    home = ENV['HOME']
    return path.to_s if home.nil? || home.empty?

    path.to_s.sub(home, '~')
  end

  def color(text, kind)
    return text unless color_enabled?

    code = case kind
    when :header
      '1;36'
    when :label
      '2;37'
    when :pick
      '1;32'
    when :range
      '1;34'
    when :source
      '2;90'
    else
      '0'
    end

    "\e[#{code}m#{text}\e[0m"
  end

  def color_enabled?
    @color_enabled ||= STDOUT.tty? && ENV['NO_COLOR'].nil?
  end

  def verbose?
    @verbose_level > 0
  end

  def extra_verbose?
    @verbose_level > 1
  end

  def source_suffix(entry)
    return '' unless extra_verbose?

    ' ' + color("(from #{entry.source})", :source)
  end
end

options = {
  force: false,
  dry_run: false,
  verbose_level: 0,
  selected_groups: [],
}

parser = OptionParser.new do |opts|
  opts.banner = <<~BANNER
    Usage: rotate-wallpaper [--force] [--dry-run] [-v] [-g group[,group...]] [static|resume]

    Examples:
      rotate-wallpaper -g pets
      rotate-wallpaper --group=family,pets --dry-run -v
      rotate-wallpaper -g family -g pets
  BANNER

  opts.on('--force', 'If static mode marker exists, remove it and rotate') do
    options[:force] = true
  end

  opts.on('--dry-run', 'Show selected wallpaper without updating symlink') do
    options[:dry_run] = true
  end

  opts.on('-v', '--verbose', 'Show weighted candidates (use -vv for source paths)') do
    options[:verbose_level] += 1
  end

  opts.on('-gGROUPS', '--group=GROUPS', 'Only consider wallpapers in these groups (comma separated, repeatable)') do |value|
    names = value.split(',').map(&:strip).reject(&:empty?)
    options[:selected_groups].concat(names)
  end

  opts.on('-h', '--help', 'Show this help') do
    puts opts
    exit 0
  end
end

parser.parse!

if options[:force] && options[:dry_run]
  abort('Cannot combine --force with --dry-run')
end

command = ARGV.shift
if ARGV.any?
  abort("Unexpected arguments: #{ARGV.join(' ')}")
end

case command
when 'static'
  if STATIC_FILE.exist?
    puts "Already in static mode: #{STATIC_FILE}"
  else
    STATIC_FILE.write('static')
    puts "Wallpaper rotation paused (created #{STATIC_FILE})"
  end
  exit 0
when 'resume'
  options[:force] = true
when nil
  # default behavior
else
  abort("Unknown command: #{command}")
end

exit WallpaperRotator.new(
  config_file: CONFIG_FILE,
  static_file: STATIC_FILE,
  link_target: LINK_TARGET,
  force: options[:force],
  dry_run: options[:dry_run],
  verbose_level: options[:verbose_level]
).tap { |rotator|
  rotator.selected_groups = options[:selected_groups].uniq
}.run
