
# Run in foreground
run: stop cleanup-state
  LANG="en_US.UTF-8" sketchybar

# Start background service
[group('Service')]
start:
  brew services start felixkratz/formulae/sketchybar

# Stop background service
[group('Service')]
stop:
  brew services stop felixkratz/formulae/sketchybar

# Kill all sketchybar instances
[group('Service')]
kill:
  pkill sketchybar || true
  rm -f /tmp/sketchybar_*.lock

# Cleanup stale Aerospace/SketchyBar refresh state
[group('Service')]
cleanup-state:
  rm -rf /tmp/sketchybar-aerospace-refresh.lock
  rm -f /tmp/sketchybar-aerospace-items.state
  rm -f /tmp/sketchybar-aerospace-last-refresh.ts
  rm -f /tmp/sketchybar-aerospace-*

# Update sketchybar workspace highlighting and icons
[group('Service')]
update:
  plugins/aerospace.sh --refresh

# Force a manual AeroSpace workspace refresh
[group('Service')]
refresh-aerospace:
  plugins/aerospace.sh --refresh

# Hide macOS menu bar
[group('System')]
hide-bar:
  defaults write NSGlobalDomain _HIHideMenuBar -bool true
  killall Dock

# Show macOS menu bar
[group('System')]
show-bar:
  defaults write NSGlobalDomain _HIHideMenuBar -bool false
  killall Dock
