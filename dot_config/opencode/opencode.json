{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/src/lshq/**": "allow",
      "~/src/erebusbat/**": "allow",
      "~/.local/share/mise/installs/ruby/**": "allow",
      "~/.rbenv/**": "allow",
    }
  },
	"disabled_providers": [
		"openai"
  ],
  "share": "disabled",
  "experimental": {
    "disable_paste_summary": true
  },
  "plugin": [
    "opencode-gemini-auth",
    "opencode-smart-voice-notify@latest",
    "@different-ai/opencode-browser"
  ],
  "mcp": {
    "obsidian": {
      "type": "local",
      "command": [
        "/Users/andrew.burns/bin/.mcp-obsidian.sh"
      ]
    },
    "todoist": {
      "type": "local",
      "command": [
        "/Users/andrew.burns/bin/.mcp-todoist.sh"
      ]
    },
    "tmux": {
      "type": "local",
      "command": [
        "/Users/andrew.burns/bin/.mcp-tmux.sh"
      ]
    },
    "memory": {
      "type": "local",
      "command": [
        "/Users/andrew.burns/bin/.mcp-memory.sh"
      ]
    }
  }
}
