{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/src/lshq/**": "allow",
      "~/src/erebusbat/**": "allow",
      "~/.local/share/mise/installs/ruby/**": "allow",
      "~/.rbenv/**": "allow",
    }
  },
	"disabled_providers": [
  ],
  "share": "disabled",
  "experimental": {
    "disable_paste_summary": true
  },
  "plugin": [
    "opencode-gemini-auth",
    "opencode-smart-voice-notify@latest",
    "@different-ai/opencode-browser"
  ],
  "mcp": {
    "obsidian": {
      "type": "local",
      "command": [
        "/Users/andrew.burns/bin/.mcp-obsidian.sh"
      ]
    },
    "todoist": {
      "type": "local",
      "command": [
        "/Users/andrew.burns/bin/.mcp-todoist.sh"
      ]
    },
    "tmux": {
      "type": "local",
      "command": [
        "/Users/andrew.burns/bin/.mcp-tmux.sh"
      ]
    },
    "memory": {
      "type": "local",
      "command": [
        "/Users/andrew.burns/bin/.mcp-memory.sh"
      ]
    }
  },
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": [
          "reasoning.encrypted_content"
        ],
        "store": false
      },
      "models": {
        "gpt-5.2": {
          "name": "GPT 5.2 (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
